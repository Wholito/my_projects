rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function roundDoc(roundId) {
      return get(/databases/$(database)/documents/rounds/$(roundId));
    }

    function roundExists(roundId) {
      return exists(/databases/$(database)/documents/rounds/$(roundId));
    }

    function isRoundAuthor(roundId) {
      return isSignedIn()
        && roundExists(roundId)
        && roundDoc(roundId).data.authorUid == request.auth.uid;
    }

    function isRoundParticipant(roundId) {
      return isSignedIn()
        && roundExists(roundId)
        && (
          request.auth.uid == roundDoc(roundId).data.authorUid
          || request.auth.uid in roundDoc(roundId).data.invitedUids
        );
    }

    function onlyProfileFieldsChanged() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['displayName'])
        || keys.hasOnly(['avatarUrl'])
        || keys.hasOnly(['displayName', 'avatarUrl']);
    }

    function onlyFcmFieldsChanged() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['fcmToken'])
        || keys.hasOnly(['fcmUpdatedAt'])
        || keys.hasOnly(['fcmToken', 'fcmUpdatedAt']);
    }

    function onlyScoreFieldsChanged() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      let oldScore = resource.data.get('totalScore', 0);
      let oldPlayed = resource.data.get('roundsPlayed', 0);
      return keys.hasOnly(['totalScore', 'roundsPlayed'])
        && request.resource.data.totalScore >= oldScore
        && request.resource.data.roundsPlayed == oldPlayed + 1;
    }

    function roundGuesses(data) {
      return data.get('guesses', []);
    }

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll([
          'displayName', 'email', 'friendCode', 'createdAt'
        ])
        && request.resource.data.get('totalScore', 0) == 0
        && request.resource.data.get('roundsPlayed', 0) == 0;

      allow update: if isOwner(uid) && (
        onlyProfileFieldsChanged()
        || onlyFcmFieldsChanged()
        || onlyScoreFieldsChanged()
      );

      allow delete: if false;

      match /friends/{friendUid} {
        allow read: if isOwner(uid);
        allow create, delete: if isOwner(uid)
          || (isSignedIn() && request.auth.uid == friendUid);
        allow update: if false;
      }

      match /friend_requests/{fromUid} {
        allow read: if isOwner(uid)
          || (isSignedIn() && request.auth.uid == fromUid);
        allow create: if isSignedIn()
          && request.auth.uid == fromUid
          && request.resource.data.fromUid == fromUid
          && request.resource.data.fromName is string
          && request.resource.data.createdAt is timestamp;
        allow delete: if isOwner(uid)
          || (isSignedIn() && request.auth.uid == fromUid);
        allow update: if false;
      }

      match /feed/{roundId} {
        allow read: if isOwner(uid);
        allow create: if isSignedIn()
          && request.resource.data.roundId == roundId
          && request.resource.data.receivedAt is timestamp
          && isRoundAuthor(roundId)
          && uid in roundDoc(roundId).data.invitedUids;
        allow update, delete: if false;
      }
    }

    match /rounds/{roundId} {
      allow read: if isRoundParticipant(roundId);

      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.photoUrl is string
        && request.resource.data.realLocation is map
        && request.resource.data.invitedUids is list
        && request.resource.data.guesses is list
        && request.resource.data.status is string
        && request.resource.data.createdAt is timestamp;

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.invitedUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guesses'])
        && roundGuesses(request.resource.data).size()
            == roundGuesses(resource.data).size() + 1;

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
